{
  "name": "@saeris/configs",
  "version": "1.0.0",
  "description": "Shared Vite+ configurations (Oxlint, Oxfmt, and TypeScript)",
  "keywords": [
    "vite-plus",
    "oxlint",
    "oxfmt",
    "oxc",
    "tsconfig",
    "config",
    "lint",
    "format"
  ],
  "homepage": "https://github.com/Saeris/configs#readme",
  "license": "MIT",
  "author": "Drake Costa <drake@saeris.gg> (https://saeris.gg)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Saeris/configs.git"
  },
  "files": [
    "dist/**/*",
    "src/tsconfig.base.json"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "development": "./src/index.ts",
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./tsconfig": "./src/tsconfig.base.json",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "ci": "vp check && vp test",
    "build": "vp pack",
    "check": "vp check",
    "format": "vp check --fix",
    "test": "vp test --fileParallelism"
  },
  "peerDependencies": {
    "vite-plus": "*"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@varlock/bumpy": "^1.7.0",
    "@vitest/coverage-v8": "^4.1.6",
    "typescript": "6.0.3",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "resolutions": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "yarn@4.16.0"
}
